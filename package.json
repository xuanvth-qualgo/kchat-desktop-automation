  "description": "git clone \"https://github.com/xuanvth-qualgo/kchat-desktop-automation.git\" && cd kchat-desktop-automation",
  "scripts": {
    "test": "node scripts/test-filter.js",
    "first-login": "npx playwright test first-login",
    "cleanrpt": "rm -rf allure-results allure-report",
    "genrpt": "rm -rf allure-report && npx allure generate allure-results -o allure-report",
    "openrpt": "npx allure open allure-report",
    "serverpt": "npx allure serve allure-results",
    "ci": "./scripts/run-and-report.sh"
  },
